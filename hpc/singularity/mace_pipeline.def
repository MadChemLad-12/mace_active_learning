Bootstrap: docker
From: nvidia/cuda:11.8.0-cudnn8-runtime-ubuntu22.04

%post
    apt-get update -y && apt-get install -y python3-pip git
    
    pip3 install torch==2.0.1+cu118 \
        --extra-index-url https://download.pytorch.org/whl/cu118
    
    # Your specific stack — one env so no e3nn conflict
    pip3 install mace-torch ase scikit-learn \
        numpy pandas matplotlib pyyaml

%environment
    # Fallback defaults — overridden by host env vars at runtime
    export MACE_FOUNDATION_MODEL="mace-mp-0b3-medium-float32.model"
    export CP2K_LIBDIR="/usr/share/cp2k/data"

%runscript
    exec python3 "$@"